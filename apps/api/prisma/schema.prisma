generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  collections   Collection[]
  priceJobs     PriceRefreshJob[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Card {
  id              String              @id
  name            String
  supertype       String?
  subtypes        String[]
  hp              String?
  types           String[]
  setId           String
  setName         String
  rarity          String?
  imageSmall      String?
  imageLarge      String?
  raw             Json
  fetchedAt       DateTime
  expiresAt       DateTime
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  collectionItems CollectionItem[]
  priceSnapshots  CardPriceSnapshot[]
  priceJobItems   PriceRefreshJobItem[]
}

model Set {
  id           String   @id
  name         String
  series       String?
  releaseDate  String?
  total        Int?
  printedTotal Int?
  logo         String?
  symbol       String?
  raw          Json
  fetchedAt    DateTime
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CardSearchCache {
  id         String   @id @default(cuid())
  queryHash  String   @unique
  query      String
  page       Int
  pageSize   Int
  orderBy    String?
  cardIds    String[]
  count      Int
  totalCount Int
  fetchedAt  DateTime
  expiresAt  DateTime
  updatedAt  DateTime @updatedAt

  @@index([expiresAt])
}

model SetSearchCache {
  id         String   @id @default(cuid())
  queryHash  String   @unique
  query      String
  page       Int
  pageSize   Int
  orderBy    String?
  setIds     String[]
  count      Int
  totalCount Int
  fetchedAt  DateTime
  expiresAt  DateTime
  updatedAt  DateTime @updatedAt

  @@index([expiresAt])
}

enum CollectionKind {
  owned
  favorites
  wishlist
  binder
}

model Collection {
  id        String           @id @default(cuid())
  userId    String
  kind      CollectionKind
  name      String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CollectionItem[]
  priceJobs PriceRefreshJob[]

  @@unique([userId, kind, name])
  @@index([userId, kind])
}

model CollectionItem {
  id                 String     @id @default(cuid())
  collectionId       String
  cardId             String
  quantity           Int        @default(1)
  condition          String?
  finish             String?
  language           String     @default("en")
  notes              String?
  purchasePriceCents Int?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  collection         Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  card               Card       @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([collectionId, cardId])
  @@index([cardId])
}

enum PriceStatus {
  pending
  success
  failed
  blocked
  not_found
  missing_url
  skipped
}

enum PriceRefreshJobStatus {
  queued
  running
  completed
  failed
}

model CardPriceSnapshot {
  id                   String      @id @default(cuid())
  cardId               String
  pricingUrl           String?
  status               PriceStatus
  productName          String?
  cardNumber           String?
  rarity               String?
  printedInSet         String?
  availableItems       Int?
  fromPriceCents       Int?
  priceTrendCents      Int?
  avgSellPrice30dCents Int?
  avgPrice7dCents      Int?
  avgPrice1dCents      Int?
  currency             String?
  lastError            String?
  rawExtractedJson     Json?
  fetchedAt            DateTime    @default(now())
  createdAt            DateTime    @default(now())
  card                 Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  jobItems             PriceRefreshJobItem[]

  @@index([cardId, fetchedAt])
  @@index([status])
}

model PriceRefreshJob {
  id           String                @id @default(cuid())
  userId       String
  collectionId String
  status       PriceRefreshJobStatus @default(queued)
  total        Int                   @default(0)
  processed    Int                   @default(0)
  succeeded    Int                   @default(0)
  failed       Int                   @default(0)
  skipped      Int                   @default(0)
  startedAt    DateTime?
  finishedAt   DateTime?
  error        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection   Collection            @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  items        PriceRefreshJobItem[]

  @@index([userId, createdAt])
  @@index([collectionId, createdAt])
}

model PriceRefreshJobItem {
  id          String             @id @default(cuid())
  jobId       String
  cardId      String
  pricingUrl  String?
  status      PriceStatus        @default(pending)
  error       String?
  snapshotId  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  job         PriceRefreshJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  card        Card                @relation(fields: [cardId], references: [id], onDelete: Cascade)
  snapshot    CardPriceSnapshot?  @relation(fields: [snapshotId], references: [id], onDelete: SetNull)

  @@unique([jobId, cardId])
  @@index([cardId])
  @@index([status])
}
